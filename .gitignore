# ===== Unity =====
# Сгенерированные папки (восстанавливаются Unity автоматически)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Никогда не игнорировать .meta внутри Assets
!/[Aa]ssets/**/*.meta

# Файлы, генерируемые IDE из проекта Unity
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# .meta для удалённых pdb/mdb
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Отчёты и сборки
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
crashlytics-build.properties

# Addressables и StreamingAssets
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ===== ОС =====
Thumbs.db
Desktop.ini
.DS_Store

# ===== Редакторы и IDE =====
.vscode/
.idea/

# ===== Web-прототип (на будущее) =====
node_modules/
dist/

